// Lydie'shop — Schéma Prisma
// La boutique qui sublime les Reines

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Connexion runtime : sur Supabase, pointe sur le Supavisor transaction
  // pooler (port 6543) avec `?pgbouncer=true&connection_limit=1`. Sur Vercel
  // serverless, ça évite d'épuiser le quota de connexions directes.
  url       = env("DATABASE_URL")
  // Connexion directe, utilisée UNIQUEMENT par `prisma migrate` / `db push`
  // (opérations schéma incompatibles avec le pooler transaction mode). Sur
  // Supabase, c'est le port 5432. Optionnelle au runtime : si absente, seul
  // `prisma migrate` plantera, pas le serveur.
  directUrl = env("DIRECT_URL")
}

// ---------- UTILISATEURS ----------

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  phone        String?
  passwordHash String
  role         Role     @default(CUSTOMER)
  loyaltyPoints Int     @default(0)
  tier         Tier     @default(ROSE)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  addresses           Address[]
  orders              Order[]
  wishlist            WishlistItem[]
  reviews             Review[]
  chatSessions        ChatSession[]
  passwordResetTokens PasswordResetToken[]
  beautyProfile       BeautyProfile?
}

enum Role {
  CUSTOMER
  ADMIN
  SUPER_ADMIN
}

enum Tier {
  ROSE
  GOLD
  DIAMOND
}

model Address {
  id         String  @id @default(cuid())
  userId     String
  firstName  String
  lastName   String
  street     String
  city       String
  postalCode String
  country    String  @default("FR")
  phone      String?
  isDefault  Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- PRODUITS ----------

model Product {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String   @db.Text
  shortDesc        String
  price            Decimal
  comparePrice     Decimal?
  stock            Int      @default(0)
  categoryId       String
  tags             String[]
  features         String[] @default([])
  careInstructions String?  @db.Text
  isFeatured       Boolean  @default(false)
  isNew            Boolean  @default(false)
  isActive         Boolean  @default(true)
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  weight           Float?
  seoTitle         String?
  seoDesc          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category      Category          @relation(fields: [categoryId], references: [id])
  images        ProductImage[]
  variants      ProductVariant[]
  attributes    ProductAttribute[]
  orderItems    OrderItem[]
  wishlistItems WishlistItem[]
  reviews       Review[]
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  color     String?
  length    String?
  stock     Int      @default(0)
  price     Decimal?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  url       String
  alt       String?
  position  Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Category {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  image              String?
  isActive           Boolean             @default(true)
  position           Int                 @default(0)
  products           Product[]
  attributeTemplates AttributeTemplate[]
}

// ---------- PARAMÈTRES BOUTIQUE ----------

// Singleton — un seul row en base, mis à jour par l'admin.
model ShopSettings {
  id                  String  @id @default("singleton")
  shopName            String  @default("Lydie'shop")
  contactEmail        String  @default("contact@lydie-shop.fr")
  instagramUrl        String? @default("https://instagram.com/lydieshop")
  tiktokUrl           String?
  facebookUrl         String?
  promoBarMessage     String? @default("Livraison offerte dès 60€ · Cadeau surprise dans chaque commande")
  maintenanceMode     Boolean @default(false)
  maintenanceMessage  String? @default("La boutique est en maintenance. Revenez bientôt !")
  freeShippingThreshold Float @default(60)
  colissimoPrice      Float   @default(5.90)
  mondialRelayPrice   Float   @default(3.90)
  chronopostPrice     Float   @default(12.90)
  colissimoEnabled    Boolean @default(true)
  mondialRelayEnabled Boolean @default(true)
  chronopostEnabled   Boolean @default(true)
  updatedAt           DateTime @updatedAt
}

// ---------- ATTRIBUTS DYNAMIQUES ----------

enum AttributeType {
  TEXT
  SELECT
  NUMBER
  BOOLEAN
}

model AttributeTemplate {
  id         String        @id @default(cuid())
  categoryId String
  name       String
  type       AttributeType @default(TEXT)
  unit       String?
  options    String[]      @default([])
  isRequired Boolean       @default(false)
  position   Int           @default(0)

  category Category           @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  values   ProductAttribute[]

  @@unique([categoryId, name])
  @@index([categoryId])
}

model ProductAttribute {
  id         String @id @default(cuid())
  productId  String
  templateId String
  value      String

  product  Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  template AttributeTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([productId, templateId])
}

// ---------- COMMANDES ----------

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  guestEmail      String?
  status          OrderStatus   @default(PENDING)
  subtotal        Decimal
  shippingCost    Decimal
  discount        Decimal       @default(0)
  total           Decimal
  promoCodeId     String?
  shippingAddress Json
  paymentIntent   String?
  paymentStatus   PaymentStatus @default(PENDING)
  trackingNumber  String?
  carrier         String?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user      User?       @relation(fields: [userId], references: [id])
  items     OrderItem[]
  promoCode PromoCode?  @relation(fields: [promoCodeId], references: [id])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  variantId String?
  quantity  Int
  price     Decimal
  name      String
  image     String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ---------- FIDÉLITÉ ----------

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model PromoCode {
  id        String    @id @default(cuid())
  code      String    @unique
  type      PromoType
  value     Decimal
  minOrder  Decimal?
  maxUses   Int?
  usedCount Int       @default(0)
  isActive  Boolean   @default(true)
  expiresAt DateTime?

  orders Order[]
}

enum PromoType {
  PERCENT
  FIXED
  FREE_SHIPPING
}

// ---------- AVIS ----------

model Review {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  comment    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

// ---------- PRÉFÉRENCES BEAUTÉ ----------

model BeautyProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  hairType       String[] @default([])  // fins, épais, bouclés, lisses, crépus
  desiredLength  String[] @default([])  // courte, mi-longue, longue, très longue
  favoriteColors String[] @default([])  // noir, châtain, blond, miel, rouge, fantaisie
  budgetRange    String?                // <100€, 100-200€, 200-300€, 300€+
  occasions      String[] @default([])  // quotidien, travail, soirée, mariage, sport
  notes          String?  @db.Text      // instructions libres
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- RÉINITIALISATION MOT DE PASSE ----------

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------- CHATBOT ----------

model ChatSession {
  id        String   @id @default(cuid())
  userId    String?
  messages  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])
}
